# Your Gmail address
SMTP_USER=abc@gmail.com

# Gmail App Password (NOT your real Gmail password)
# How to get it:
#   1. Go to myaccount.google.com
#   2. Security → 2-Step Verification (must be ON)
#   3. Search "App passwords" → Select app: Mail → Generate
#   4. Copy the 16-character code and paste below (no spaces)
SMTP_PASS=your_16_char_app_password_here

# Your frontend URL (for CORS in production)
# Local dev: http://localhost:5500
# Production: https://your-portfolio.vercel.app
FRONTEND_URL=http://localhost:5500

# Port (optional, default is 3001)
PORT=3001
